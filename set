import numpy as np
import matplotlib.pyplot as plt

np.random.seed(0)

X = np.linspace(25, 35, 150)
y = np.sin(X) + np.random.normal(0, 0.25, size=X.shape)

# Linear regression (underfit)
coeffs = np.polyfit(X, y, 1)
model = np.poly1d(coeffs)

# Plot
plt.scatter(X, y)
plt.plot(X, model(X), color='red')
plt.title("Underfitting Model")
plt.show()
