import numpy as np
import matplotlib.pyplot as plt

np.random.seed(0)

X = np.linspace(10, 20, 150)
y = np.cos(X) + np.random.normal(0, 0.4, size=X.shape)

# Polynomial regression (overfit)
coeffs = np.polyfit(X, y, 10)
model = np.poly1d(coeffs)

# Plot
plt.scatter(X, y)
plt.plot(X, model(X), color='red')
plt.title("Overfitting Model")
plt.show()

