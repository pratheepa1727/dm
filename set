import numpy as np
from sklearn import datasets
import pandas as pd
import matplotlib.pyplot as plt

# Load dataset
wine = datasets.load_wine()

# Convert to DataFrame
wine_df = pd.DataFrame(wine.data, columns=wine.feature_names)

# (i) Shape
print("Shape:", wine_df.shape)

# (ii) Descriptive statistics
print(wine_df.describe())

# (iii) Top 7 and Last 8 rows
print(wine_df.head(7))
print(wine_df.tail(8))

# (iv) Boxplot - malic_acid
plt.boxplot(wine_df['malic_acid'])
plt.title("Boxplot of malic_acid")
plt.show()

# (v) Remove outliers (IQR)
Q1 = wine_df['malic_acid'].quantile(0.25)
Q3 = wine_df['malic_acid'].quantile(0.75)
IQR = Q3 - Q1

filtered_df = wine_df[(wine_df['malic_acid'] >= Q1 - 1.5*IQR) &
                      (wine_df['malic_acid'] <= Q3 + 1.5*IQR)]

plt.boxplot(filtered_df['malic_acid'])
plt.title("After removing outliers")
plt.show()

# (vi) Histogram - magnesium
plt.hist(wine_df['magnesium'], bins=20)
plt.title("Histogram of magnesium")
plt.show()
